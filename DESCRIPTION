Package: NanopixR
Type: Package
Title: Automated Analysis of Nanoparticles for Biotechnological Applications
Version: 0.1.0
Authors@R: c(
    person(
      "Ronja", "Tittel",
      email = "ronja.tittel@b-tu.de",
      role = c("aut", "cre")
